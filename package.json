{
  "name": "fresh-pantry-monorepo",
  "private": true,
  "scripts": {
    "api:test": "cd apps/api && npm test",
    "api:deploy": "cd apps/api && npx wrangler deploy",
    "supabase:start": "npx -y supabase@2.101.0 start",
    "supabase:stop": "npx -y supabase@2.101.0 stop",
    "supabase:status": "npx -y supabase@2.101.0 status",
    "supabase:reset": "npx -y supabase@2.101.0 db reset",
    "check": "npm run api:test"
  }
}
