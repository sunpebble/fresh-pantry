        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "1つのウィジェットで期限間近・今日の食事・買い物・減廃を切り替え"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un widget pour basculer entre péremption, repas, courses et anti-gaspillage"
          }
        }
      }
    },
