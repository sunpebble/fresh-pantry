    "widget.config.configurable.description": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "一个组件切换 临期 / 今日膳食 / 购物 / 减废"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "One widget switches between expiring, meals, shopping, and waste reduction"
          }
