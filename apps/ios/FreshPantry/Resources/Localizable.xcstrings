    "inventory.clearAll.message %lld": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将删除全部 %lld 件食材，不计入减废统计，此操作无法撤销。"
          }
        },
        "en": {
          "variations": {
            "plural": {
              "one": {
                "stringUnit": {
                  "state": "translated",
                  "value": "This deletes all %lld ingredient. It won't count toward your waste stats, and can't be undone."
                }
              },
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "This deletes all %lld ingredients. It won't count toward your waste stats, and can't be undone."
                }
              }
            }
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld件の食材がすべて削除されます。廃棄削減の統計には反映されず、この操作は取り消せません。"
          }
        },
        "fr": {
          "variations": {
            "plural": {
              "one": {
                "stringUnit": {
                  "state": "translated",
                  "value": "Cela supprime tout %lld ingrédient. Il ne sera pas compté dans vos statistiques anti-gaspillage, et cette action est irréversible."
                }
              },
              "other": {
                "stringUnit": {
                  "state": "translated",
                  "value": "Cela supprime tous les %lld ingrédients. Ils ne seront pas comptés dans vos statistiques anti-gaspillage, et cette action est irréversible."
