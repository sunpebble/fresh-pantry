    "settings.reminder.footer" : {
      "localizations" : {
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "提醒在开启系统通知权限后送达。开启「仅每日汇总」可关闭逐条临期推送、只保留一条汇总;免打扰时段内逐条提醒不再打扰。" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Reminders arrive once system notification permission is granted. Turn on \"Daily summary only\" to stop individual expiry pushes and keep just one summary; individual reminders stay quiet during quiet hours." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "システムの通知許可をオンにするとリマインダーが届きます。「まとめて通知のみ」をオンにすると個別の期限通知を止めて、まとめ通知だけになります。おやすみ時間帯は個別通知も届きません。" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Les rappels arrivent une fois l'autorisation de notification système accordée. Activez « Résumé quotidien uniquement » pour arrêter les notifications individuelles et ne garder qu'un résumé ; pendant les heures calmes, les rappels individuels restent silencieux." } }
      }
    },
