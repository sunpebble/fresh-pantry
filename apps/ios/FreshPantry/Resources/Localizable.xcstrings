    "settings.ai.saveFailed": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "保存失败：无法写入钥匙串(Keychain)，配置未保存，请重试。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Save failed: could not write to the Keychain. Your settings were not saved — please try again."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "保存に失敗しました：キーチェーン(Keychain)に書き込めませんでした。設定は保存されていません。もう一度お試しください。"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Échec de l'enregistrement : impossible d'écrire dans le trousseau (Keychain). Vos paramètres n'ont pas été enregistrés, veuillez réessayer."
          }
        }
      }
    },
