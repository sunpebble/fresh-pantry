    "settings.clearHistory.message": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将删除所有「常买」记录（添加频次与默认分类/存储位置），此操作不可撤销。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This deletes all frequent-item records (add counts and remembered category/location). This can't be undone."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「よく買う」の記録（追加回数と既定のカテゴリー・保管場所）をすべて削除します。元に戻せません。"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ceci supprime tous les enregistrements d'articles fréquents (nombre d'ajouts et catégorie/emplacement mémorisés). Action irréversible."
          }
        }
      }
    },
    "settings.clearHistory.subtitle": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "重置添加频次与记住的默认值"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Resets add counts and remembered defaults"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "追加回数と既定値の記憶をリセット"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Réinitialise les compteurs et valeurs mémorisées"
          }
        }
      }
    },
    "settings.clearHistory.title": {
      "localizations": {
