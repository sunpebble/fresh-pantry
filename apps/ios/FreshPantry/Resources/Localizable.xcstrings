      "localizations" : {
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "导入备份" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Import backup" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "バックアップをインポート" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Importer une sauvegarde" } }
