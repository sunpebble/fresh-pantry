    "sync.failure.clearConfirm.message %lld": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将丢弃 %lld 个项目的未同步更改，此操作不可撤销。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This will discard unsynced changes for %lld items. This cannot be undone."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld件の未同期変更を破棄します。この操作は元に戻せません。"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les modifications non synchronisées de %lld éléments seront supprimées. Cette action est irréversible."
          }
        }
      }
    },
    "sync.failure.clearConfirm.title": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "清除失败记录？"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Clear failed records?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "失敗記録を消去しますか？"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Effacer les échecs ?"
          }
        }
      }
    },
    "sync.failure.empty.message": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "所有待同步内容已恢复正常。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "All pending sync items are healthy again."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "保留中の同期項目はすべて正常に戻りました。"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tous les éléments en attente de synchronisation sont à nouveau normaux."
          }
        }
      }
    },
    "sync.failure.empty.title": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "没有同步失败项"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No sync failures"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "同期失敗はありません"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucun échec de synchronisation"
          }
        }
      }
    },
    "sync.failure.footer": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这些写入多次同步失败，已暂时停止重试。可重试一次，或清除失败记录（会丢弃这些未同步的更改）。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "These writes failed repeatedly and are paused. You can retry once or clear the failed records, which discards the unsynced changes."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "これらの書き込みは繰り返し失敗したため一時停止されています。1回再試行するか、未同期の変更を破棄して失敗記録を消去できます。"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ces écritures ont échoué plusieurs fois et sont suspendues. Vous pouvez réessayer une fois ou effacer les échecs, ce qui supprimera les modifications non synchronisées."
          }
        }
      }
    },
    "sync.failure.header": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "同步失败的项目"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Failed sync items"
          }
        },
        "ja": {
