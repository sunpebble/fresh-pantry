      }
    },
    "backup.export.action.title" : {
      "localizations" : {
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "导出备份" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Export backup" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "バックアップをエクスポート" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Exporter la sauvegarde" } }
      }
    },
    "backup.export.copy.subtitle" : {
      "localizations" : {
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "复制备份 JSON，可粘贴到备忘录/邮件保存" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Copy the backup JSON, then paste it into Notes or an email to keep it" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "バックアップのJSONをコピーし、メモやメールに貼り付けて保存できます" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Copiez le JSON de sauvegarde, puis collez-le dans Notes ou un e-mail pour le conserver" } }
      }
    },
    "backup.export.copy.title" : {
      "localizations" : {
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "复制到剪贴板" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Copy to clipboard" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "クリップボードにコピー" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Copier dans le presse-papiers" } }
      }
    },
    "backup.export.copySuccess %lld" : {
      "localizations" : {
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "已复制 %lld 字节，粘贴到备忘录/邮件即可保存" } },
        "en" : { "variations" : { "plural" : {
          "one" : { "stringUnit" : { "state" : "translated", "value" : "Copied %lld byte. Paste it into Notes or an email to keep it." } },
          "other" : { "stringUnit" : { "state" : "translated", "value" : "Copied %lld bytes. Paste it into Notes or an email to keep it." } }
        } } },
