          "one" : { "stringUnit" : { "state" : "translated", "value" : "%lld octet copié. Collez-le dans Notes ou un e-mail pour le conserver." } },
          "other" : { "stringUnit" : { "state" : "translated", "value" : "%lld octets copiés. Collez-les dans Notes ou un e-mail pour les conserver." } }
        } } }
