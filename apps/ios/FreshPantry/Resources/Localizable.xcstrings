        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cet appareil contient encore %@. Après l'adhésion, ces données resteront dans votre espace personnel et seront temporairement masquées. Pour les conserver et les partager, créez d'abord un foyer."
          }
