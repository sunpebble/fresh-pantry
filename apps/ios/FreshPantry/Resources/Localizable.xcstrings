{
  "sourceLanguage" : "zh-Hans",
  "strings" : {
    "error.ai.authExpired" : {
      "localizations" : {
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "登录已过期，请重新登录" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Your session has expired. Please sign in again." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "ログインの有効期限が切れました。再度ログインしてください" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Session expirée, veuillez vous reconnecter" } }
      }
    },
    "error.ai.authFailed %lld" : {
      "localizations" : {
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "认证失败 (%lld)" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Sign-in failed (%lld)" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "認証に失敗しました (%lld)" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Échec de l'authentification (%lld)" } }
      }
    },
    "error.ai.busy" : {
      "localizations" : {
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "服务繁忙 (429)" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Service is busy (429)" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "サービスが混み合っています (429)" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Service occupé (429)" } }
      }
    },
    "error.ai.cancelled" : {
      "localizations" : {
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "已取消" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Cancelled" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "キャンセルしました" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Annulé" } }
      }
    },
    "error.ai.emptyResponse" : {
      "localizations" : {
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "响应中无 content" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "The response contains no content" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "レスポンスに content がありません" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "La réponse ne contient aucun contenu" } }
      }
    },
    "error.ai.network %@" : {
      "localizations" : {
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "网络错误：%@" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Network error: %@" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "ネットワークエラー：%@" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Erreur réseau : %@" } }
      }
    },
    "error.ai.notConfigured" : {
      "localizations" : {
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "AI 服务未配置" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "AI service not set up" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "AIサービスが未設定です" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Service IA non configuré" } }
      }
    },
    "error.ai.notFound" : {
      "localizations" : {
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "接口不存在 (404)。Base URL 应填写到 /v1，例如 https://example.com/v1，不要包含 /chat/completions" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Endpoint not found (404). The base URL should end at /v1, e.g. https://example.com/v1 — do not include /chat/completions" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "エンドポイントが見つかりません (404)。Base URL は /v1 まで入力してください（例：https://example.com/v1）。/chat/completions は含めないでください" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Point d'accès introuvable (404). L'URL de base doit s'arrêter à /v1, p. ex. https://example.com/v1, sans /chat/completions" } }
      }
    },
    "error.ai.parse %@" : {
      "localizations" : {
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "解析响应失败: %@" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Failed to parse the response: %@" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "レスポンスの解析に失敗しました: %@" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Échec de l'analyse de la réponse : %@" } }
      }
    },
    "error.ai.quotaExhausted" : {
      "localizations" : {
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "今天的 AI 次数用完了，明天再来" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "You've used up today's AI quota. Come back tomorrow!" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "本日のAI利用回数を使い切りました。また明日どうぞ" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Quota IA du jour épuisé, revenez demain" } }
      }
    },
    "error.ai.serverError %lld" : {
      "localizations" : {
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "服务错误 (%lld)" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Server error (%lld)" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "サーバーエラー (%lld)" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Erreur du serveur (%lld)" } }
      }
    },
    "error.ai.timeout" : {
      "localizations" : {
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "请求超时" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Request timed out" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "リクエストがタイムアウトしました" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Délai de la requête dépassé" } }
      }
    },
    "error.ai.unexpectedStatus %lld %@" : {
      "localizations" : {
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "意外状态 (%1$lld)%2$@" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Unexpected status (%1$lld)%2$@" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "予期しないステータス (%1$lld)%2$@" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Statut inattendu (%1$lld)%2$@" } }
      }
    },
    "notification.dailySummary.body" : {
      "localizations" : {
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "查看今天到期 / 已过期食材" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "See what expires or has expired today" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "今日期限・期限切れの食材を確認" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Voir les aliments qui expirent ou ont expiré aujourd'hui" } }
      }
    },
    "notification.dailySummary.bodyWithLowStock %lld" : {
      "localizations" : {
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "查看今天到期 / 已过期食材 · 库存不足 %lld 项" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "See today's expiring items · %lld running low" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "今日期限の食材を確認 · 在庫不足 %lld 件" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Aliments du jour · %lld en stock faible" } }
      }
    },
    "notification.dailySummary.title" : {
      "localizations" : {
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "每日临期提醒" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Daily expiry check" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "毎日の期限チェック" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Rappel quotidien des péremptions" } }
      }
    },
    "notification.expiry.body %@ %@ %lld" : {
      "localizations" : {
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "%1$@ %2$@ 还剩 %3$lld 天" } },
        "en" : { "variations" : { "plural" : {
          "one" : { "stringUnit" : { "state" : "translated", "value" : "%1$@ (%2$@) — %3$lld day left" } },
          "other" : { "stringUnit" : { "state" : "translated", "value" : "%1$@ (%2$@) — %3$lld days left" } }
        } } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "%1$@ %2$@ あと%3$lld日" } },
        "fr" : { "variations" : { "plural" : {
          "one" : { "stringUnit" : { "state" : "translated", "value" : "%1$@ (%2$@) — %3$lld jour restant" } },
          "other" : { "stringUnit" : { "state" : "translated", "value" : "%1$@ (%2$@) — %3$lld jours restants" } }
        } } }
      }
    },
    "notification.expiry.title %lld" : {
      "localizations" : {
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "%lld 天后过期" } },
        "en" : { "variations" : { "plural" : {
          "one" : { "stringUnit" : { "state" : "translated", "value" : "Expires in %lld day" } },
          "other" : { "stringUnit" : { "state" : "translated", "value" : "Expires in %lld days" } }
        } } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "%lld日後に期限切れ" } },
        "fr" : { "variations" : { "plural" : {
          "one" : { "stringUnit" : { "state" : "translated", "value" : "Expire dans %lld jour" } },
          "other" : { "stringUnit" : { "state" : "translated", "value" : "Expire dans %lld jours" } }
        } } }
      }
    },
