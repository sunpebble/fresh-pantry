    "household.create.description": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "创建后,本机现有的库存、采购、食谱、膳食计划与食材去向记录会成为这个家庭的初始数据。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "After creation, this device's pantry, shopping list, recipes, meal plan, and food log become the household's initial data."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "作成後、この端末の在庫、買い物、レシピ、献立、食材ログがこの家庭の初期データになります。"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Après la création, le stock, les courses, les recettes, les repas et le journal alimentaire de cet appareil deviendront les données initiales du foyer."
          }
        }
      }
    },
