    "backup.import.footer": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "导入会覆盖本机当前数据。无效或版本不支持的文件会被拒绝，不会破坏现有数据。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Importing overwrites your current data on this device. Invalid or unsupported files are rejected without touching your existing data."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "インポートすると、この端末の現在のデータが上書きされます。無効なファイルや対応していないバージョンは拒否され、既存データは変更されません。"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'importation remplace les données actuelles de cet appareil. Les fichiers invalides ou dont la version n'est pas prise en charge sont rejetés sans toucher à vos données existantes."
          }
        }
