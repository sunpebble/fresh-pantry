    "backup.export.failure" : {
      "localizations" : {
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "导出失败，请重试" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Export failed. Please try again." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "エクスポートに失敗しました。もう一度お試しください。" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Échec de l'exportation. Veuillez réessayer." } }
      }
    },
    "backup.export.footer" : {
      "localizations" : {
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "备份包含库存、采购清单、自建食谱、膳食计划、食材去向记录、菜谱收藏、饮食偏好与忌口、提醒设置与 AI 配置；不含外观设置与可重建的食材详情缓存。" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "The backup includes inventory, shopping list, custom recipes, meal plans, ingredient-usage history, recipe favorites, dietary preferences and exclusions, reminder settings, and AI configuration. It excludes appearance settings and the rebuildable ingredient-detail cache." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "バックアップには在庫、買い物リスト、自作レシピ、献立プラン、食材の消費履歴、お気に入りレシピ、食事の好みと禁忌食材、リマインダー設定、AI設定が含まれます。外観設定と再構築可能な食材詳細キャッシュは含まれません。" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "La sauvegarde comprend le stock, la liste de courses, les recettes personnalisées, les plans de repas, l'historique d'utilisation des ingrédients, les recettes favorites, les préférences et exclusions alimentaires, les réglages de rappel et la configuration IA. Elle exclut les réglages d'apparence et le cache des détails d'ingrédients (reconstructible)." } }
      }
    },
    "backup.export.header" : {
      "localizations" : {
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "导出" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Export" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "エクスポート" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Exporter" } }
      }
    },
