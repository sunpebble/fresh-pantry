    "recipe.photoImport.hint": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择一张纸质菜谱、手写菜谱或聊天截图，先离线识别文字，再由 AI 整理成食谱草稿供你核对。"
