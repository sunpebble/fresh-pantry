    "auth.local.card.message": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此版本未配置 Supabase 后端,无法登录。库存、采购与食谱仍可在本机正常使用。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This build has no Supabase backend, so sign-in is disabled. Pantry, shopping, and recipes still work locally."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このビルドにはSupabaseバックエンドがないためログインできません。在庫、買い物、レシピは端末内で利用できます。"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette version n'a pas de backend Supabase, la connexion est donc désactivée. Le stock, les courses et les recettes fonctionnent toujours localement."
          }
        }
      }
    },
    "auth.local.card.title": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "登录已禁用"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sign-in disabled"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ログインは無効です"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Connexion désactivée"
          }
        }
      }
    },
    "backup.error.invalidFile": {
