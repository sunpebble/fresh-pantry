    "auth.header.signedIn.subtitle": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "登录后即可在家庭成员间同步库存与采购。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your pantry and shopping list can sync with household members."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "在庫と買い物リストを家族メンバーと同期できます。"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre stock et vos courses peuvent se synchroniser avec les membres du foyer."
          }
        }
      }
    },
    "auth.header.signedIn.title": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已登录"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Signed in"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
