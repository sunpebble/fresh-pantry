    "inventory.batchRemoveOutcome.message": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "它们怎么了?用于统计你的减废成效。删除后可撤销。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "What happened to them? This feeds your waste-reduction stats. You can undo the removal."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "どうなりましたか？廃棄削減の統計に使用されます。削除後も取り消せます。"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Qu'est-il devenu ? Cela alimente vos statistiques anti-gaspillage. Vous pouvez annuler la suppression."
          }
        }
      }
    },
