    "auth.error.generic": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "操作失败,请稍后重试"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Something went wrong. Try again later."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "操作に失敗しました。しばらくしてからもう一度お試しください。"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'opération a échoué. Réessayez plus tard."
          }
        }
      }
    },
    "auth.error.invalidEmail": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请输入有效的邮箱地址"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enter a valid email address"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "有効なメールアドレスを入力してください"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Saisissez une adresse e-mail valide"
          }
        }
      }
    },
    "auth.error.invalidOtp": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "验证码不正确,请重新输入"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The code is incorrect. Try again."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "認証コードが正しくありません。もう一度入力してください。"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le code est incorrect. Réessayez."
          }
        }
      }
    },
    "auth.error.network": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "网络连接失败,请检查网络后重试"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Network connection failed. Check your connection and try again."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ネットワーク接続に失敗しました。接続を確認してもう一度お試しください。"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La connexion réseau a échoué. Vérifiez votre connexion et réessayez."
          }
        }
      }
    },
    "auth.error.otpExpired": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "验证码已失效,请重新获取"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The code has expired. Request a new one."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "認証コードの有効期限が切れました。再取得してください。"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le code a expiré. Demandez-en un nouveau."
          }
        }
      }
    },
    "auth.error.rateLimit": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请求过于频繁,请稍后再试"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Too many requests. Try again later."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "リクエストが多すぎます。しばらくしてからお試しください。"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Trop de demandes. Réessayez plus tard."
          }
        }
      }
    },
    "auth.header.codeSent.subtitle": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "我们已向你的邮箱发送了 6 位验证码。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We sent a 6-digit code to your email."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "6桁の認証コードをメールに送信しました。"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nous avons envoyé un code à 6 chiffres à votre adresse e-mail."
          }
        }
      }
    },
    "auth.header.local.subtitle": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未配置后端,当前为本地模式。数据仅保存在本机。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No backend is configured. Data stays on this device."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "バックエンド未設定のためローカルモードです。データはこの端末だけに保存されます。"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucun backend n'est configuré. Les données restent sur cet appareil."
          }
        }
      }
    },
    "auth.header.local.title": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "本地模式"
