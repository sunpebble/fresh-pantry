{
  "sourceLanguage": "zh-Hans",
  "strings": {
    "app.invite.acknowledge": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "知道了"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Got it"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "了解しました"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Compris"
          }
        }
      }
    },
    "app.invite.promptSignIn": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "收到家庭邀请,请先在「设置 → 家庭共享」登录,登录后会自动继续处理。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You have a family invite. Sign in under Settings → Family Sharing first — it will resume automatically after you sign in."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "家族への招待が届いています。まず「設定 → 家族共有」でログインしてください。ログイン後、自動的に処理が続行されます。"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous avez reçu une invitation familiale. Connectez-vous d'abord dans Réglages → Partage familial — le traitement continuera automatiquement après la connexion."
          }
        }
      }
    },
    "app.invite.title": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "家庭邀请"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Family invite"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "家族への招待"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Invitation familiale"
          }
        }
      }
    },
    "app.invite.unsupported": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此版本未配置后端,无法打开家庭邀请。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This build has no backend configured, so the family invite can't be opened."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このビルドにはバックエンドが設定されていないため、家族への招待を開けません。"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette version n'a pas de backend configuré, l'invitation familiale ne peut donc pas être ouverte."
          }
        }
      }
    },
    "auth.account.title": {
      "localizations": {
