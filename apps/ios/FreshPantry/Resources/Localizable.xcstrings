    "auth.error.emptyCode": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请输入验证码"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enter the verification code"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
