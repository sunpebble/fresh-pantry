        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "清除常买记忆"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Clear frequent-item memory"
          }
        },
        "ja": {
          "stringUnit": {
