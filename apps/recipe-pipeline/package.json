{
  "name": "@fresh-pantry/recipe-pipeline",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build:recipes": "flue run build-recipes --target node --payload '{}'",
    "build:recipes:dry": "flue run build-recipes --target node --payload '{\"dryRun\":true}'",
    "i18n:recipes": "npx tsx src/db/translate-recipes.ts",
    "videos:acquire": "npx tsx src/db/acquire-videos.ts",
    "images:apply": "npx tsx src/db/apply-web-images.ts",
    "images:upload": "npx tsx src/db/upload-images.ts",
    "images:rewrite-urls": "npx tsx src/db/rewrite-image-urls.ts",
    "gen:seed": "npx tsx src/db/gen-seed.ts"
  },
  "dependencies": {
    "@flue/runtime": "^0.11.1",
    "@valibot/to-json-schema": "^1.7.1",
    "valibot": "^1.4.2"
  },
  "devDependencies": {
    "@flue/cli": "^0.11.1",
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
